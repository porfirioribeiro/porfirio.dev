		"@types/node": "^25.9.3",
		"@types/slug": "^5.0.9",
		"esbuild": "^0.28.1",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"prettier": "~3.4.2",
		"prettier-plugin-svelte": "^4.1.0",
		"sass": "^1.101.0",
		"svelte": "^5.56.3",
		"svelte-check": "^4.6.0",
